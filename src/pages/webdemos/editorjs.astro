---
import Layout from "src/layouts/Layout.astro"
import EditorJS from "src/components/EditorJS/EditorJS.svelte"
---

<Layout title="EditorJS Demo | Web Demos" description="EditorJS integration demo">
    <section class="max-w-4xl mx-auto py-8 px-4">
        <h1 class="text-3xl font-bold mb-6 text-gray-900 dark:text-white">EditorJS Demo</h1>
        <!-- Note: importan to have the client:only directive -->
        <EditorJS client:only />
    </section>
</Layout>

<style>
    section :global(.codex-editor) {
        padding: 0 16px;
    }
    section :global(.ce-block__content) {
        max-width: 100%;
    }
    section :global(.ce-toolbar__content) {
        max-width: 100%;
    }
</style>
